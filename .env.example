# App Settings
PROJECT_NAME="SkillUp API"
API_V1_STR="/api/v1"

# Security
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY="replace_with_a_strong_random_secret_key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
# For docker: postgresql://postgres:postgres_password@db:5432/skillup
# For local: postgresql://postgres:postgres_password@localhost:5432/skillup
DATABASE_URL="postgresql://postgres:postgres_password@db:5432/skillup"

# Initial Admin User (optional)
FIRST_SUPERUSER_EMAIL="admin@skillup.dz"
FIRST_SUPERUSER_PASSWORD="change_this_password"
# Set to true in production (enables secure cookies)
PRODUCTION=false
# App Settings
PROJECT_NAME="SkillUp API"
API_V1_STR="/api/v1"

# Security
SECRET_KEY="your-super-secret-key-here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 1 day

# Database
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/skillup"

# Initial Admin User
FIRST_SUPERUSER_EMAIL="admin@skillup.dz"
FIRST_SUPERUSER_PASSWORD="admin_password"
